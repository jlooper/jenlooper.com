---
/**
 * Post card — layout aligned with ProjectCard for listing grids.
 * External links open in a new tab; same-site and path-only links do not.
 */
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props extends astroHTML.JSX.HTMLAttributes {
  class?: string
  title?: string
  img?: string
  imageComponent?: ImageMetadata | Promise<{ default: ImageMetadata }>
  imageAlt?: string
  width?: number
  height?: number
  inferSize?: boolean
  url?: string
  tagName?: string
  footer?: string
}

const {
  class: className,
  title = 'Default title',
  img = 'https://fakeimg.pl/640x360',
  imageComponent,
  imageAlt = '',
  width = 640,
  height = 360,
  inferSize = false,
  url = '#',
  tagName = 'h3',
  footer = '',
  ...rest
} = Astro.props

const Tag = tagName

const effectiveImageAlt =
  imageAlt.trim() ||
  (title && title !== 'Default title' ? `Cover image for the article "${title}"` : '') ||
  'Article cover image'

const siteOrigin = Astro.site?.origin
function shouldOpenInNewTab(href: string): boolean {
  if (!href || href === '#' || href.startsWith('/')) return false
  if (!/^https?:\/\//i.test(href)) return false
  try {
    const u = new URL(href)
    if (siteOrigin && u.origin === siteOrigin) return false
    return true
  } catch {
    return false
  }
}
const openInNewTab = shouldOpenInNewTab(url)
---

<article
  class:list={[
    'post-card group relative flex h-full min-w-0 max-w-none flex-col overflow-hidden rounded-xl border border-border/50 bg-card text-card-foreground shadow-soft transition-[box-shadow,transform] duration-300 hover:-translate-y-0.5 hover:shadow-md dark:border-border/60',
    className,
  ]}
  {...rest}
>
  <div
    class="relative flex h-44 w-full shrink-0 items-center justify-center overflow-hidden border-b border-border/40 bg-muted/30 dark:bg-muted/20 sm:h-48 md:h-52 lg:h-56"
  >
    {
      imageComponent ? (
        <Image
          src={imageComponent}
          alt={effectiveImageAlt}
          width={width}
          height={height}
          inferSize={inferSize}
          class="h-full w-full object-cover object-center"
        />
      ) : (
        <img
          src={img}
          alt={effectiveImageAlt}
          width={width}
          height={height}
          class="h-full w-full object-cover object-center"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>
  <div class="relative z-0 flex flex-1 flex-col gap-2 p-5 md:gap-3 md:p-6">
    <div class="meta-area empty:hidden">
      <slot name="meta" />
    </div>
    <div class="title-area font-serif text-lg font-semibold leading-snug text-foreground md:text-xl">
      <Tag>
        <a
          class="post-card-title-link text-foreground no-underline outline-none ring-ring transition-colors hover:text-primary hover:underline hover:decoration-primary hover:underline-offset-4 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-background"
          href={url}
          {...(openInNewTab ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {title}
        </a>
      </Tag>
    </div>
    <div class="description-area text-sm leading-relaxed text-muted-foreground dark:text-foreground/95 md:text-base">
      <slot />
    </div>
    {
      footer && (
        <small class="footer mt-auto border-t border-border/50 pt-3 text-xs text-muted-foreground dark:border-border/40 md:pt-4">
          {footer}
        </small>
      )
    }
  </div>
</article>

<style>
  .post-card {
    --transition-duration: 0.3s;
    --transition-easing: cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .post-card img {
      transition: transform var(--transition-duration) var(--transition-easing);
    }
  }

  .post-card:has(.post-card-title-link:hover, .post-card-title-link:focus-visible) img {
    transform: scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card:has(.post-card-title-link:hover, .post-card-title-link:focus-visible) img {
      transform: none;
    }
  }

  .post-card-title-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .post-card :global(.description-area a) {
    position: relative;
    z-index: 2;
  }

  .title-area :global(h3) {
    margin: 0;
    line-height: 1.25;
  }

  .meta-area:empty {
    display: none;
  }

  .description-area:empty {
    display: none;
  }
</style>
