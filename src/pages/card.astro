---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import { Image } from 'astro:assets'
import jen from '../assets/img/jen.jpg'
---

<DefaultLayout title="Socials">
  <section class="card-listing-page">
    <article
      class="overflow-hidden rounded-xl border border-border/50 bg-card text-card-foreground shadow-soft dark:border-border/60"
    >
      <div class="grid grid-cols-1 gap-8 p-6 md:grid-cols-2 md:gap-12 md:p-10 lg:gap-14">
        <div class="flex items-center justify-center border-b border-border/40 pb-8 md:border-b-0 md:border-r md:pb-0 md:pr-8 lg:pr-12">
          <Image
            src={jen}
            alt="Professional photo of Jen Looper, creative technologist and tech lead"
            class="max-h-[min(420px,55vh)] w-full max-w-md object-contain object-center"
            decoding="async"
          />
        </div>
        <div class="flex flex-col justify-center gap-5 md:gap-6">
          <div class="space-y-2">
            <h1 class="font-serif text-4xl font-semibold leading-tight text-foreground md:text-5xl lg:text-6xl">
              Jen Looper
            </h1>
            <h2 class="font-serif text-2xl font-bold italic text-muted-foreground md:text-3xl">
              Creative Technologist & Tech Lead
            </h2>
          </div>
          <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap">
            <a class="button" href="https://www.linkedin.com/in/jenlooper/" target="_blank" rel="noopener noreferrer"
              >LinkedIn</a
            >
            <a class="button" href="https://x.com/jenlooper" target="_blank" rel="noopener noreferrer">Twitter (X)</a>
            <a class="button" href="https://bsky.app/profile/jenlooper.com" target="_blank" rel="noopener noreferrer"
              >Bluesky</a
            >
            <a class="button" href="https://github.com/jlooper" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a class="button" href="/contact/">Contact Me</a>
          </div>
        </div>
      </div>
    </article>
  </section>
</DefaultLayout>
