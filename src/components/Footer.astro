---
import { Github, Twitter, Linkedin, HandHeart } from 'lucide-astro'

const currentYear = new Date().getFullYear()
---

<footer class="site-footer mt-auto border-t border-border/60 bg-muted/40 text-muted-foreground dark:bg-card/40">
  <div class="mx-auto max-w-6xl px-6 py-10 md:px-12">
    <div
      class="footer-content flex flex-col items-center justify-center gap-3 text-center text-sm sm:flex-row sm:flex-wrap sm:gap-x-4 sm:gap-y-2 sm:text-left"
    >
      <div class="footer-section flex flex-wrap items-center justify-center gap-2 sm:justify-start sm:gap-3">
        <span class="text-foreground/90">&copy; {currentYear} Jen Looper</span>
        <span class="separator hidden text-border sm:inline" aria-hidden="true">|</span>
        <a
          href="/credits/"
          class="no-underline rounded font-medium text-foreground transition-colors hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
          aria-label="View site credits"
        >
          Credits
        </a>
      </div>

      <span class="separator hidden text-border sm:inline" aria-hidden="true">|</span>

      <div class="footer-social flex items-center justify-center gap-1 sm:justify-start">
        <a
          href="https://github.com/jlooper"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline rounded-md p-2 text-muted-foreground transition-colors hover:bg-muted/80 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
          aria-label="Visit Jen's GitHub profile"
        >
          <Github class="h-5 w-5" aria-hidden="true" />
        </a>
        <a
          href="https://x.com/jenlooper"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline rounded-md p-2 text-muted-foreground transition-colors hover:bg-muted/80 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
          aria-label="Follow Jen on X (formerly Twitter)"
        >
          <Twitter class="h-5 w-5" aria-hidden="true" />
        </a>
        <a
          href="https://bsky.app/profile/jenlooper.com"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline rounded-md p-2 text-muted-foreground transition-colors hover:bg-muted/80 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
          aria-label="Follow Jen on Bluesky"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide"
            aria-hidden="true"
          >
            <path
              d="M19.9,3.5 C20.85,3.5 21.34875,4.4025 21.39625,5.350125 L21.4,5.5 C21.4,6.05446404 21.3269891,7.48313344 21.1809945,9.78600994 C21.0389293,12.0167035 19.2882204,13.7824621 17.1020899,13.9813405 C18.5799137,14.403371 20,15.1676683 20,16.5 C20,18 16.5,21.5 15,21.5 C13.5972917,21.5 12.4306943,19.6111131 11.5002078,15.8333394 L11.3283556,16.4993931 C10.4270327,19.833131 9.31769565,21.5 8,21.5 C6.5,21.5 3,18 3,16.5 C3,15.1736779 4.40730428,14.4102775 5.87800492,13.9858141 C3.65451601,13.8252583 1.86279501,12.0437791 1.71900553,9.78600994 L1.58393127,7.53475816 C1.52797925,6.52149222 1.5,5.84323964 1.5,5.5 C1.5,4.5 2,3.5 3,3.5 C6.93646865,3.5 10.388694,9.79516282 11.4504675,11.4247893 L11.7721074,10.9140922 C13.1024262,8.76924222 16.29855,3.5 19.9,3.5 Z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/jenlooper/"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline rounded-md p-2 text-muted-foreground transition-colors hover:bg-muted/80 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
          aria-label="Jen Looper on LinkedIn"
        >
          <Linkedin class="h-5 w-5" aria-hidden="true" />
        </a>
      </div>

      <span class="separator hidden text-border sm:inline" aria-hidden="true">|</span>

      <div
        class="footer-built inline-flex items-center justify-center gap-1.5 text-foreground/85 sm:justify-start"
      >
        <HandHeart class="h-4 w-4 shrink-0 text-primary" aria-hidden="true" />
        <span class="whitespace-nowrap">Built with care in Boston</span>
      </div>
    </div>
  </div>
</footer>
