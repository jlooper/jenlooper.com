---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import TalkCard from '../components/TalkCard.astro'

type Talk = {
  title: string
  venue: string
  embedUrl: string
}

const talks: Talk[] = [
  {
    title: 'A la Recherche du Temps Perdu: Searching for the Cozy Web',
    venue: 'Pixelpalooza 2025',
    embedUrl: 'https://www.youtube.com/embed/P2tJEBC1eZs',
  },
  {
    title: 'The Last Saree: Connoisseurship in the Age of AI',
    venue: 'TEDx Charusat 2024',
    embedUrl: 'https://www.youtube.com/embed/y6qopiBGK-E',
  },
  {
    title: 'WineUP: ML, Mobile Apps, Wine 🍷, & Cheese 🧀',
    venue: "Script'19 — 2019",
    embedUrl: 'https://www.youtube.com/embed/ToHsJPcgKdI',
  },
  {
    title: 'The Ethics of Imagery',
    venue: 'ImageCon Keynote 2019',
    embedUrl: 'https://www.youtube.com/embed/4Zhjy3Mdtbc',
  },
  {
    title: 'The Great Minibar Challenge',
    venue: 'Vue Amsterdam 2019',
    embedUrl: 'https://www.youtube.com/embed/SgBDEydZb4A',
  },
  {
    title: 'The Zen of Vue',
    venue: 'VueConf 2019',
    embedUrl: 'https://www.youtube.com/embed/wCU-kDlXY58',
  },
  {
    title: 'Human vs. AI: Build a Mobile App with Vue.js, ML kit and NativeScript',
    venue: 'Voxxed Thessaloniki 2018',
    embedUrl: 'https://www.youtube.com/embed/ZG7GtgfUS6g',
  },
  {
    title: '3 Identical Apps with Ionic, NativeScript, and React Native',
    venue: 'Frontend Developer Love 2018',
    embedUrl: 'https://www.youtube.com/embed/1Kqtg1Mw2wc',
  },
  {
    title: 'Staying Fresh and Avoiding Burnout',
    venue: 'Keynote — Voxxed Thessaloniki 2018',
    embedUrl: 'https://www.youtube.com/embed/H4Rnh01ywJk',
  },
  {
    title: 'Create an Engaging Mobile App with NativeScript',
    venue: 'FITC Toronto 2018',
    embedUrl: 'https://www.youtube.com/embed/3kA4b8o8Wfo',
  },
]
---

<DefaultLayout title="Speaking">
  <section class="card-listing-page">
    <div class="card-listing-intro">
      <h1 class="font-serif text-4xl font-semibold leading-tight text-foreground md:text-5xl lg:text-6xl">
        Speaking
      </h1>
      <p class="text-lg leading-relaxed text-foreground/85 dark:text-foreground/95 md:text-xl">
        I'm a well-known conference speaker. Here are a few of my talks, and a
        <a
          href="https://www.youtube.com/playlist?list=PL8bLS57CI8i2idWqYbsvu9IOwjTGqReaa"
          target="_blank"
          rel="noopener noreferrer">link to my playlist on YouTube</a
        >. You can also find links to many of my slide decks
        <a href="https://www.slideshare.net/JenLooper/presentations" target="_blank" rel="noopener noreferrer"
          >on SlideShare</a
        >.
      </p>
      <p class="text-lg leading-relaxed text-foreground/85 dark:text-foreground/95 md:text-xl">
        If you'd like me to come speak at your conference, please <a href="/contact">fill out this form</a>.
      </p>
    </div>

    <hr class="card-listing-divider" />

    <ul class="card-listing-grid" aria-label="Selected talks">
      {
        talks.map((talk) => (
          <li>
            <TalkCard title={talk.title} venue={talk.venue} embedUrl={talk.embedUrl} />
          </li>
        ))
      }
    </ul>
  </section>
</DefaultLayout>
