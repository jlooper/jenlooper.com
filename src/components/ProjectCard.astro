---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

type ProjectCardLink = {
  href: string
  label: string
}

interface Props {
  image?: ImageMetadata
  imageAlt?: string
  title: string
  description: string
  links?: ProjectCardLink[]
  eager?: boolean
}

const { image, imageAlt, title, description, links = [], eager = false } = Astro.props

const hasImage = Boolean(image && imageAlt?.trim())
---

<article
  class="project-card flex h-full min-w-0 flex-col overflow-hidden rounded-xl border border-border/50 bg-card text-card-foreground shadow-soft transition-[box-shadow,transform] duration-300 hover:-translate-y-0.5 hover:shadow-md dark:border-border/60"
>
  {
    hasImage && image && imageAlt && (
      <figure
        class="flex h-44 w-full shrink-0 items-center justify-center border-b border-border/40 bg-muted/30 p-3 dark:bg-muted/20 sm:h-48 md:h-52 lg:h-56 md:p-4"
      >
        <Image
          src={image}
          alt={imageAlt}
          width={image.width}
          height={image.height}
          class="max-h-full max-w-full object-contain object-center"
          decoding="async"
          loading={eager ? 'eager' : 'lazy'}
        />
      </figure>
    )
  }
  <div
    class:list={[
      'flex flex-1 flex-col gap-3 p-5 md:gap-4 md:p-6',
      !hasImage && 'pt-6 md:pt-7',
    ]}
  >
    <h3 class="font-serif text-lg font-semibold leading-snug text-foreground md:text-xl">
      {title}
    </h3>
    <p class="flex-1 text-sm leading-relaxed text-foreground/85 dark:text-foreground/95 md:text-base">
      {description}
    </p>
    {
      links.length > 0 && (
        <div class="mt-auto flex flex-col gap-2 border-t border-border/50 pt-4 dark:border-border/40">
          {links.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group/link inline-flex items-center gap-1 text-sm font-medium text-primary no-underline transition-colors hover:text-terracotta dark:hover:text-coral-light"
            >
              {link.label}
              <span class="inline-block transition-transform group-hover/link:translate-x-0.5" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
