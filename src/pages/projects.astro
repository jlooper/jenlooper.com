---
import type { ImageMetadata } from 'astro'
import DefaultLayout from '../layouts/DefaultLayout.astro'
import ProjectCard from '../components/ProjectCard.astro'
import img1 from '../assets/img/ff-logo.png'
import img2 from '../assets/img/cc.png'
import img3 from '../assets/img/saree.png'
import img4 from '../assets/img/omb.jpg'
import img5 from '../assets/img/posedance.png'
import img6 from '../assets/img/story.png'
import img7 from '../assets/img/wineup.png'
import img8 from '../assets/img/t.jpg'
import img9 from '../assets/img/emily.png'
import img10 from '../assets/img/mix.png'
import img11 from '../assets/img/wa-color.png'
import img12 from '../assets/img/tarot.png'
import img13 from '../assets/img/glorious.png'
import tussie from '../assets/img/tussie.png'
import cccImg from '../assets/img/ccc.png'

type ProjectLink = { href: string; label: string }

type ProjectItem = {
  image: ImageMetadata
  imageAlt: string
  title: string
  description: string
  links?: ProjectLink[]
  eager?: boolean
}

const communityProjects: ProjectItem[] = [
  {
    image: cccImg,
    imageAlt: 'Cloudinary Creators Community wordmark on a dark banner background',
    title: 'Cloudinary Creators Community',
    description:
      'A global community for developers, designers, and digital storytellers who care how visual media looks, feels, and performs on the web. Members connect on Discord, join live sessions and office hours, and share creative uses of Cloudinary in the real world.',
    links: [{ href: 'https://community.cloudinary.com/', label: 'Visit the community site' }],
    eager: true,
  },
  {
    image: img1,
    imageAlt: 'Front-End Foxes nonprofit logo with fox head illustration and logotype',
    title: 'Front-End Foxes, Inc.',
    description:
      'Formerly Vue Vixens, Inc., this international nonprofit survived COVID by transforming from in-person workshops to an online school; we educated hundreds of women over five years and have several success stories.',
    links: [{ href: 'https://ff-school.jenlooper.com', label: 'Front-End Foxes school' }],
  },
  {
    image: img2,
    imageAlt: 'AWS Cloud Clubs program graphic with cloud icon and global meetup branding',
    title: 'AWS Cloud Clubs',
    description:
      'In February 2023 my team at AWS launched AWS Cloud Clubs worldwide. The program has grown immensely since then, impacting over 100,000 students in 2025 alone.',
    links: [{ href: 'https://www.meetup.com/pro/cloud-clubs', label: 'Cloud Clubs on Meetup' }],
  },
]

const demoProjects: ProjectItem[] = [
  {
    image: tussie,
    imageAlt:
      'Tussie-Mussie Generator web app interface showing Victorian-style flower bouquet selections',
    title: 'Tussie-Mussie Generator',
    description:
      "Showcasing Cloudinary's image recognition capabilities, this app generates a tussie-mussie based on a selection of flowers by their meaning. Send it as an e-card!",
    links: [
      { href: 'https://youtu.be/L8H4SnNUeDs', label: 'Watch the demo (YouTube)' },
      { href: 'https://tussie-mussies.netlify.app/', label: 'Try it on Netlify' },
    ],
  },
  {
    image: img3,
    imageAlt: 'Saree Detector mobile app screens identifying traditional South Asian textile patterns',
    title: 'Saree Detector App',
    description:
      'This app was built as a demo to show how image recognition capabilities can be used for artisan textiles, to enhance connoisseurship.',
    links: [{ href: 'https://youtu.be/y6qopiBGK-E', label: 'Watch the TEDx talk' }],
  },
  {
    image: img4,
    imageAlt: 'Ombromanie shadow-puppet storytelling web app with silhouette hands on a warm-lit screen',
    title: 'Ombromanie',
    description:
      'Tell stories with just your hands—and use hand poses to capture them via a web app!',
    links: [{ href: 'https://github.com/jlooper/ombromanie', label: 'GitHub repository' }],
  },
  {
    image: img5,
    imageAlt: "PoseDance TikTok trainer app comparing a dancer's pose to an on-screen outline",
    title: 'PoseDance: a TikTok trainer app',
    description:
      'Learn how to dance like an influencer on TikTok with this web app, which uses body poses to track and score your smooth moves.',
    links: [{ href: 'https://github.com/jlooper/posedance', label: 'GitHub repository' }],
  },
  {
    image: img6,
    imageAlt: 'Project Troubadour storytelling web app connecting museum objects into a narrative path',
    title: 'Project Troubadour: a storytelling web app',
    description:
      "Created with Microsoft and the Smithsonian's Cooper Hewitt Museum of Design—use a museum API to construct connected stories.",
    links: [{ href: 'https://github.com/jlooper/storytelling-app', label: 'GitHub repository' }],
  },
  {
    image: img7,
    imageAlt: 'WineUp pocket sommelier app showing wine and cheese pairing suggestions on a phone',
    title: 'WineUp: your pocket sommelier',
    description:
      'Wine and cheese pairings, powered by ML and the Wine Spectator API. A mobile app demo.',
    links: [{ href: 'https://github.com/jlooper/wineup', label: 'GitHub repository' }],
  },
  {
    image: img8,
    imageAlt: 'Twist & Shout Beatles tribute app collage with album art and British invasion graphics',
    title: 'Twist & Shout: Beatles tribute app',
    description:
      'A mobile app celebrating the Beatles with ML song generators, an album cover recreation tool, and more.',
    links: [{ href: 'https://github.com/jlooper/twistnshout', label: 'GitHub repository' }],
  },
  {
    image: img9,
    imageAlt: 'EMiLy Emily Dickinson tribute app with poetry and portrait-inspired visuals',
    title: 'EMiLy: Emily Dickinson tribute app',
    description: "Celebrate Emily Dickinson's oeuvre with ML-generated poetry.",
    links: [{ href: 'https://github.com/jlooper/emily', label: 'GitHub repository' }],
  },
  {
    image: img10,
    imageAlt: 'MixoLogy minibar scanner app identifying bottles and suggesting cocktail recipes on mobile',
    title: "MixoLogy: what's in my minibar?",
    description:
      "Take a photo of your minibar's contents, get a cocktail suggestion, or shake the phone for an AI-generated recipe idea.",
    links: [{ href: 'https://github.com/jlooper/mixology-mobile', label: 'GitHub repository' }],
  },
  {
    image: img11,
    imageAlt: 'Well-Architected Framework coloring book pages with AWS pillar-themed line art',
    title: 'The Well-Architected coloring book',
    description:
      "To reinforce the ideas behind the six pillars of the framework, here's a coloring book that will help you remember them.",
    links: [{ href: 'https://jenlooper.gumroad.com/l/wa-color', label: 'Get it on Gumroad' }],
  },
  {
    image: img12,
    imageAlt: 'AWS Tarot deck website mock-up with cloud-service themed tarot card artwork',
    title: 'AWS Tarot',
    description: 'The companion site for a not-too-serious tarot deck that references AWS services.',
    links: [{ href: 'https://aws-tarot.netlify.app', label: 'View on Netlify' }],
  },
  {
    image: img13,
    imageAlt:
      'Ye Glorious Historiae of Ye Cloud comic strip in medieval tapestry style about cloud computing',
    title: 'Ye Glorious Historiae of Ye Cloud',
    description:
      'A completely anachronistic journey into cloud computing topics using Bayeux imagery. Because why not.',
    links: [
      {
        href: 'https://www.webtoons.com/en/canvas/ye-glorious-historiae-of-ye-cloud/list?title_no=926508',
        label: 'Read on Webtoon',
      },
    ],
  },
]
---

<DefaultLayout title="Projects">
  <section class="card-listing-page">
    <div class="card-listing-intro">
      <h1 class="font-serif text-4xl font-semibold leading-tight text-foreground md:text-5xl lg:text-6xl">
        Projects
      </h1>
      <p class="text-lg leading-relaxed text-foreground/85 dark:text-foreground/95 md:text-xl">
        I've been creating community and exciting, creative demos and interesting projects for years. Discover
        some of them here. Many are powered by the
        <a target="_blank" rel="noopener noreferrer" href="https://www.kaggle.com/jenlooper/datasets">datasets</a> I
        manage on Kaggle. You can download several of the free items associated with these projects on
        <a target="_blank" rel="noopener noreferrer" href="https://jenlooper.gumroad.com/">Gumroad</a>.
      </p>
    </div>

    <div class="card-listing-section-head">
      <h2 class="font-serif text-2xl font-bold italic text-foreground md:text-3xl">Global Communities</h2>
      <p class="card-listing-section-deck">
        Long-running programs and communities—built for learners and practitioners worldwide.
      </p>
    </div>

    <ul class="card-listing-grid" aria-label="Global community projects">
      {
        communityProjects.map((project) => (
          <li>
            <ProjectCard
              image={project.image}
              imageAlt={project.imageAlt}
              title={project.title}
              description={project.description}
              links={project.links}
              eager={project.eager}
            />
          </li>
        ))
      }
    </ul>

    <hr class="card-listing-divider" />

    <div class="card-listing-section-head-spaced">
      <h2 class="font-serif text-2xl font-bold italic text-foreground md:text-3xl">Educational and fun demos</h2>
      <p class="card-listing-section-deck">
        Experiments in ML, mobile, and the web—often tied to conference talks or teaching.
      </p>
    </div>

    <ul class="card-listing-grid" aria-label="Educational and demo projects">
      {
        demoProjects.map((project) => (
          <li>
            <ProjectCard
              image={project.image}
              imageAlt={project.imageAlt}
              title={project.title}
              description={project.description}
              links={project.links}
              eager={project.eager}
            />
          </li>
        ))
      }
    </ul>
  </section>
</DefaultLayout>
